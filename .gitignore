# 원본 데이터 — 크기 1.46GB, 절대 커밋 금지
data/raw/

# Python 캐시
__pycache__/
*.pyc
*.pyo
.env

# IDE
.vscode/
.idea/

# Playwright MCP 디버그 산출물 (스크린샷 테스트용, 커밋 대상 아님)
