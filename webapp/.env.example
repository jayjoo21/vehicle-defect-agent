LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# 알림 구독 기능(발표 시연용 "지금 알림 보내기" 버튼)이 사용하는 Slack Incoming Webhook URL.
# 비워두면 에러 없이 "미설정" 응답만 돌아온다(정상 폴백). 값은 여기(.env.example)에 넣지
# 말고 webapp/.env(gitignore 대상)에만 채운다. 배포(Render 등) 시에는 이 값을 Render
# 환경변수에도 별도로 등록해야 배포된 데모에서 실제로 발송된다.
SLACK_WEBHOOK_URL=
